# ─────────────────────────────────────────────────────────
# A&M Importaciones — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el .env real al repositorio.
# ─────────────────────────────────────────────────────────

# Base de datos PostgreSQL (Neon, Supabase u otro proveedor)
DATABASE_URL=postgresql://USUARIO:CONTRASENA@HOST/NOMBRE_DB?sslmode=verify-full&channel_binding=require

# Clave secreta para firmar JWT  (mínimo 32 bytes aleatorios)
# Genera una con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CAMBIA_ESTO_POR_UNA_CLAVE_ALEATORIA_DE_64_CHARS

# Puerto del servidor (opcional, por defecto 3000)
PORT=3000

# Entorno: development | production
NODE_ENV=development

# Orígenes CORS permitidos (separados por coma)
# Ejemplo producción: https://tudominio.com
ALLOWED_ORIGINS=http://localhost:3000

# Cloudinary (subida de imágenes de productos)
CLOUDINARY_CLOUD_NAME=TU_CLOUD_NAME
CLOUDINARY_API_KEY=TU_API_KEY
CLOUDINARY_API_SECRET=TU_API_SECRET
CLOUDINARY_UPLOAD_PRESET=TU_PRESET

# WhatsApp (checkout vía WhatsApp en tienda pública)
# Formato: código de país + número, sin + ni espacios
WHATSAPP_NUMBER=51XXXXXXXXX

# Contraseña para el script seed-admin.js (solo uso local)
# ADMIN_PASSWORD=CambiarEstoPorUnaClaveSegura
